<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <staticContent>
      <!-- Ensure video MIME types are registered (webm often missing in IIS) -->
      <remove fileExtension=".mp4" />
      <mimeMap fileExtension=".mp4" mimeType="video/mp4" />
      <remove fileExtension=".webm" />
      <mimeMap fileExtension=".webm" mimeType="video/webm" />
      <remove fileExtension=".webmanifest" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      <!-- Explicit JS MIME so the Service Worker registers reliably -->
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="application/javascript" />
    </staticContent>

    <rewrite>
      <rules>
        <!-- 1. Force HTTPS (must run before any rewrite) -->
        <rule name="Force HTTPS" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://www.aqlvision.pt/{R:0}" redirectType="Permanent" />
        </rule>

        <!-- 2. Canonicalize apex aqlvision.pt to www.aqlvision.pt -->
        <rule name="Force www" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{HTTP_HOST}" pattern="^aqlvision\.pt$" ignoreCase="true" />
          </conditions>
          <action type="Redirect" url="https://www.aqlvision.pt/{R:0}" redirectType="Permanent" />
        </rule>

        <!-- 3. Serve bundled assets when requested from nested routes -->
        <rule name="AQL Vision assets from nested routes" stopProcessing="true">
          <match url="^.+/assets/(.+)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{DOCUMENT_ROOT}/assets/{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="assets/{R:1}" />
        </rule>

        <!-- 4. Serve root-level static files (logo, SW, manifest, favicon) from nested routes -->
        <rule name="AQL Vision public files from nested routes" stopProcessing="true">
          <match url="^.+/(aql-engineering-logo\.png|sw\.js|manifest\.webmanifest|favicon\.ico)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{DOCUMENT_ROOT}/{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="{R:1}" />
        </rule>

        <!-- 5. SPA fallback: any non-file, non-directory request -> index.html -->
        <rule name="AQL Vision SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="index.html" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

  <!-- Service Worker specific headers: widest scope + never cache -->
  <location path="sw.js">
    <system.webServer>
      <httpProtocol>
        <customHeaders>
          <add name="Service-Worker-Allowed" value="/" />
          <add name="Cache-Control" value="no-cache, no-store, must-revalidate" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
